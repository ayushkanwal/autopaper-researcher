# Core profile
AUTOPAPER_PROFILE_NAME=default
AUTOPAPER_QUERY_PRESET=general_time_series_v1
AUTOPAPER_QUERIES_JSON=[]
AUTOPAPER_SOURCES=arxiv,pubmed,openalex
AUTOPAPER_COLLECTION_NAME=autopaper-ingested
AUTOPAPER_MAX_NEW=2
AUTOPAPER_MAX_RESULTS_PER_QUERY=25
AUTOPAPER_MIN_RELEVANCE_SCORE=6
AUTOPAPER_REPORT_DIR=reports
AUTOPAPER_STATE_DIR=.autopaper_state
AUTOPAPER_ATTACH_REAL_PDFS=false
AUTOPAPER_ENABLE_GITHUB_SEARCH=true

# Scheduler
AUTOPAPER_SCHEDULE_CRON=0 9 * * *
AUTOPAPER_TIMEZONE=UTC
AUTOPAPER_RUN_ON_START=false

# Ranking overrides (JSON arrays)
AUTOPAPER_BOOST_TERMS_JSON=[]
AUTOPAPER_PENALTY_TERMS_JSON=[]
AUTOPAPER_INCLUDE_TERMS_JSON=[]
AUTOPAPER_EXCLUDE_TERMS_JSON=[]

# Summary provider
AUTOPAPER_SUMMARIZER=offline
AUTOPAPER_SUMMARY_FALLBACK=offline
AUTOPAPER_LLM_BASE_URL=
AUTOPAPER_LLM_API_KEY=
AUTOPAPER_LLM_MODEL=
AUTOPAPER_LLM_TIMEOUT_SECONDS=60
AUTOPAPER_SUMMARY_COMMAND=

# Zotero
ZOTERO_USER_ID=
ZOTERO_API_KEY=

# Source-specific settings
PUBMED_EMAIL=
PUBMED_API_KEY=
OPENALEX_MAILTO=
GITHUB_TOKEN=
